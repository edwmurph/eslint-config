{
  "name": "@edwmurph/eslint-config",
  "version": "7.0.1",
  "description": "Flat ESLint configs for Node.js and React",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./nodejs": "./nodejs.js",
    "./react": "./react.js"
  },
  "files": [
    "index.js",
    "nodejs.js",
    "react.js"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prerelease": "npm version prerelease --preid=rc && npm publish --tag next",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=24"
  },
  "author": "edward",
  "license": "MIT",
  "homepage": "https://github.com/edwmurph/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edwmurph/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/edwmurph/eslint-config/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
